dth: 413px) {\n  body[class=\"body-padding\"] {\n      padding: 0 !important;\n  }\n  /* HIDE CONTENT ON MOBILE */\n  td[class=\"mobile-hide-xs\"], td[class=\"mobile-hide-xs comment-gfx\"]{\n    display:none;\n  }\n  /* ADJUST BUTTONS ON MOBILE */\n  table[class=\"mobile-button-container\"]{\n      margin:0 auto;\n      width:100% !important;\n  }\n}\n\n/* Android fix */\ndiv[style*=\"margin: 16px 0;\"] { margin: 0 !important; }\n\n\n/* MARKDOWN RENDERING STYLES */\n.markdown-code {\n    background-color: #EAEAEA;\n}\n\n.markdown-table {\n    border: 1;\n    border-collapse: collapse;\n    border-style: solid;\n    border-width: thin;\n    border-color: #A6A6A6;\n    padding: 8px 10px 10px 10px;\n}\n\n        /* FILE-LIST-SPECIFIC STYLES */\n.file-delete {\n    text-decoration: line-through;\n}\n\n/* COMMENT-SPECIFIC STYLES */\n\n.new-pr-comment {\n    background-color: #0078d4;\n}\n\n.pr-comment-spacer {\n    padding: 0px;\n}\n\n.pr-comment-content {\n    padding: 5px;\n}\n\n.pr-comment-date {\n    color: #737373;\n    font-size: 14px;\n    font-weight: 400;\n    margin-left: 5px;\n}\n\n.pr-comment-like {\n    color: #737373;\n    margin-left: 5px;\n}\n\n.pr-reviewer-name {\n    font-weight: 600;\n}\n\n\n</style>\n</head>\n<body>\n\n\n<div style=\"display: none; font-size: 1px; max-height: 0px; max-width: 0px; opacity: 0; overflow: hidden; color: white\">\n    Demo User completed the pull request\n</div>\n\n\n\n<div class=\"container\" style=\"font-family: 'Segoe UI', '-apple-system', 'BlinkMacSystemFont', 'Roboto', 'Arial', sans-serif; color: #212121; font-size: 14px; background: #f8f8f8\">\n<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\">\n    <tr>\n        <td class=\"mobile-hide\" style=\"background-color: white; border-bottom: solid #eaeaea 1px\"></td>\n        <td class=\"content\" width=\"640\" style=\"padding: 0px; max-width: 640px; background-color: white; border-bottom: solid #eaeaea 1px\">\n            <!--[if (gte mso 9)|(IE)]> \n